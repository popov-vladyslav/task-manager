# Copy to .env (repo root) and fill in. The server reads this file in dev;
# in production (Render) these come from the service's environment.

# ---- API (server) — required for Phase 1 ----
DATABASE_URL=postgres://user:pass@host/db?sslmode=require  # Neon pooled connection string
JWT_SECRET=                                                # openssl rand -hex 32
OWNER_EMAIL=you@example.com                                # only this address can sign in
APP_URL=http://localhost:8081                              # web app base URL (magic-link target)
# ALLOWED_ORIGINS=https://task-tracker.net,http://localhost:8081  # CORS allowlist (comma-separated browser origins); default includes task-tracker.net + onrender + localhost
TZ=Europe/Warsaw
# PORT is provided by the host (Render). Defaults to 4000 locally.
# RESEND_API_KEY=                                          # optional; when unset, dev logs the magic link

# ---- Web app (Expo) — build-time, EXPO_PUBLIC_* is inlined into the bundle ----
# EXPO_PUBLIC_API_URL=http://localhost:4000                # set to the deployed API URL in prod

# ---- MCP server + OAuth (claude.ai connector) ----
MCP_TOKEN=                                                 # openssl rand -hex 32; also the OAuth approval secret. Unset => /mcp disabled
MCP_BASE_URL=https://api.task-tracker.net                  # public base URL the MCP server advertises (OAuth issuer + /.well-known/oauth-protected-resource + WWW-Authenticate). Falls back to PUBLIC_URL / RENDER_EXTERNAL_URL / localhost
# PUBLIC_URL=http://localhost:4000                         # legacy; kept only as a fallback for MCP_BASE_URL

# ---- Phase 3 (not needed yet) ----
# R2_ACCOUNT_ID=  R2_ACCESS_KEY=  R2_SECRET=  R2_BUCKET=
# EXPO_ACCESS_TOKEN=
