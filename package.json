{
  "name": "task-manager",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "server",
    "app"
  ],
  "scripts": {
    "server": "npm --workspace server run dev",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:seed": "npm --workspace server run db:seed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "npm --workspace @task-manager/shared exec tsc -- --noEmit && npm --workspace app run typecheck && npm --workspace server run typecheck",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.19.0"
  }
}
